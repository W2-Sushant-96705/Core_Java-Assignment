package com.sunbeam.assignment03.student;

import java.util.Scanner;

public class student {

	String name;
	int rollno;
	int std;
	Double marks;
	
	public student() {
		
	}

	public student(String name,int rollno,int std,Double marks) {
		this.name = name;
		this.rollno = rollno;
		this.std = std;
		this.marks = marks;
	}

	public String getName() {
		return name;
	}

	public void setName(String name) {
		this.name = name;
	}

	public int getRollno() {
		return rollno;
	}

	public void setRollno(int rollno) {
		this.rollno = rollno;
	}

	public int getStd() {
		return std;
	}

	public void setStd(int std) {
		this.std = std;
	}

	public Double getMarks() {
		return marks;
	}

	public void setMarks(Double marks) {
		this.marks = marks;
	}
	
	void accept_student() {
		Scanner sc = new Scanner(System.in);
		
		System.out.println("Enter your name : ");
		name = sc.nextLine();
		System.out.println("Enter your RollNo. : ");
		sc.nextLine();
		rollno = sc.nextInt();
		System.out.println("Enter your Std : ");
		std = sc.nextInt();
		System.out.println("Enter your Percentage : ");
		marks = sc.nextDouble();
	}
	
	void display_student() {
		System.out.println("\nName : "+name);
		System.out.println("RollNo. : "+rollno);
		System.out.println("Std : "+std+" th" );
		System.out.println("Percentage : "+marks+" %" );

	}

}


